# ─── Application ──────────────────────────────────────────────────────────────

# Public domain name (required in production for Traefik TLS and CORS)
DOMAIN=satellites.example.com

# Email for Let's Encrypt ACME certificate notifications
ACME_EMAIL=admin@example.com

# ─── Observability ────────────────────────────────────────────────────────────

# Grafana admin password (default: admin — change in production)
GRAFANA_ADMIN_PASSWORD=change-me-in-production

# Sentry DSN for backend error tracking (optional)
SENTRY_DSN=

# ─── Auth ─────────────────────────────────────────────────────────────────────

# API key required for future write endpoints (passed as X-Api-Key header)
API_KEY=

# ─── Backup ───────────────────────────────────────────────────────────────────

# rclone remote name and bucket path for SQLite backups (e.g. b2:my-bucket or s3:my-bucket)
# Configure with: rclone config (see scripts/backup-sqlite.sh for details)
BACKUP_REMOTE=

# Number of days to retain backups (default: 30)
BACKUP_RETENTION_DAYS=30

# ─── Deployment (GitHub Actions secrets — never commit these) ─────────────────
#
# DEPLOY_HOST     — IP or hostname of the production VPS
# DEPLOY_USER     — SSH user on the VPS (e.g. deploy)
# DEPLOY_SSH_KEY  — Private key for SSH access (the full PEM content)
# GITHUB_TOKEN    — Automatically provided by GitHub Actions for GHCR push
