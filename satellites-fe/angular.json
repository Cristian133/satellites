{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "satellites-frontend": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              },
              {
                "glob": "**/*",
                "input": "node_modules/cesium/Build/CesiumUnminified/Workers",
                "output": "cesium/Workers"
              },
              {
                "glob": "**/*",
                "input": "node_modules/cesium/Build/CesiumUnminified/ThirdParty",
                "output": "cesium/ThirdParty"
              },
              {
                "glob": "**/*",
                "input": "node_modules/cesium/Build/CesiumUnminified/Assets",
                "output": "cesium/Assets"
              },
              {
                "glob": "**/*",
                "input": "node_modules/cesium/Build/CesiumUnminified/Widgets",
                "output": "cesium/Widgets"
              }
            ],
            "styles": [
              "node_modules/cesium/Build/CesiumUnminified/Widgets/widgets.css",
              "src/styles.scss"
            ],
            "budgets": [
              {
                "type": "initial",
                "maximumWarning": "6mb",
                "maximumError": "8mb"
              },
              {
                "type": "anyComponentStyle",
                "maximumWarning": "6kb",
                "maximumError": "10kb"
              }
            ],
            "allowedCommonJsDependencies": [
              "cesium",
              "urijs",
              "protobufjs/dist/minimal/protobuf.js",
              "mersenne-twister",
              "lerc",
              "bitmap-sdf",
              "grapheme-splitter",
              "nosleep.js"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "6mb",
                  "maximumError": "8mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kb",
                  "maximumError": "10kb"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "satellites-frontend:build:production"
            },
            "development": {
              "buildTarget": "satellites-frontend:build:development"
            }
          },
          "defaultConfiguration": "development",
          "options": {
            "proxyConfig": "proxy.conf.json"
          }
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    }
  }
}